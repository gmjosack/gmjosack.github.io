---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Made By Gare">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="text-6xl font-bold text-accent-orange mb-4">404</h1>
    <p class="text-text-secondary text-lg mb-8">You're off in the weeds...</p>
    <a
      href="/"
      class="text-sm font-medium px-4 py-2 rounded bg-accent-orange/10 text-accent-orange hover:bg-accent-orange/20 transition-colors"
    >
      Check out some Projects
    </a>
  </div>
</BaseLayout>
