---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects, categoryLabels, categoryOrder, softwareSubsections } from '../data/projects';
---

<BaseLayout title="Made By Gare">
  {categoryOrder.map((category) => {
    if (category === 'software') {
      const topLevel = projects.filter((p) => p.category === 'software');
      return (
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 text-accent-orange">{categoryLabels[category]}</h2>
          {topLevel.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
              {topLevel.map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          )}
          {softwareSubsections.map((subsection) => (
            <div class="mb-8">
              <h3 class="text-xl font-semibold mb-2 text-text-primary">{subsection.label}</h3>
              {subsection.description && (
                <p class="text-text-secondary text-sm mb-4">{subsection.description}</p>
              )}
              {subsection.groups.map((group) => (
                <div class="mb-6">
                  {group.description && (
                    <p class="text-text-secondary text-sm mb-3">{group.description}</p>
                  )}
                  <div class={`grid grid-cols-1 gap-4 ${
                    subsection.compact
                      ? 'md:grid-cols-3 lg:grid-cols-4'
                      : group.columns === 3
                        ? 'md:grid-cols-3'
                        : 'md:grid-cols-2'
                  }`}>
                    {group.projects.map((project) => (
                      <ProjectCard project={project} compact={subsection.compact} />
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ))}
        </section>
      );
    }

    const categoryProjects = projects.filter((p) => p.category === category);
    if (categoryProjects.length === 0) return null;
    return (
      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-4 text-accent-orange">{categoryLabels[category]}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {categoryProjects.map((project) => (
            project.spacer
              ? <div class="hidden md:block" />
              : <div class={project.featured ? "md:col-span-2" : ""}>
                  <ProjectCard project={project} featured={project.featured} />
                </div>
          ))}
        </div>
      </section>
    );
  })}

  <section class="mb-12 border-t border-bg-tertiary pt-8">
    <p class="text-text-secondary text-sm mb-4">...and too many more projects to list. Find some more of my projects where I have repos:</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {[
        { href: 'https://github.com/gmjosack/', label: 'Personal Repos' },
        { href: 'https://github.com/made-by-gare', label: 'Made By Gare' },
        { href: 'https://github.com/spelunky-fyi', label: 'Spelunky FYI' },
        { href: 'https://github.com/ZeroCostGoods', label: 'Zero Cost Goods' },
      ].map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium px-4 py-2 rounded bg-bg-secondary border border-bg-tertiary text-text-secondary hover:text-accent-orange hover:border-accent-orange/30 transition-colors flex items-center justify-center gap-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          {link.label}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
