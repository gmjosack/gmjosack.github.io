---
import fs from 'fs';
import Papa from 'papaparse';
import path from 'path';

const csvText = fs.readFileSync(path.resolve('./src/data/full_schedule.csv'), 'utf-8').replace(/^\uFEFF/, '');
const { data: rawRows } = Papa.parse(csvText, { header: true, skipEmptyLines: true });

type Session = {
  title: string;
  startTime: string;
  endTime: string;
  startMinutes: number;
  endMinutes: number;
  day: string;
  description: string;
  location: string;
  tracks: string[];
  format: string;
  passes: string[];
  speakers: string;
  recorded: string;
};

const DAY_ORDER = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'];

function timeToMinutes(s: string) {
  if (!s || s === 'TBD') return -1;
  const t = s.includes(' ') ? s.split(' ')[1] : s;
  const [h, m] = t.split(':').map(Number);
  return h * 60 + m;
}

const sessions: Session[] = (rawRows as any[])
  .filter((r) => r['start time'] && r['start time'] !== 'TBD')
  .map((r) => ({
    title: r['session title']?.trim() ?? '',
    startTime: r['start time']?.trim() ?? '',
    endTime: r['end time']?.trim() ?? '',
    startMinutes: timeToMinutes(r['start time']),
    endMinutes: timeToMinutes(r['end time']),
    day: r['day']?.trim() ?? '',
    description: r['description']?.trim() ?? '',
    location: r['location']?.trim().replace(/^,\s*/, '').replace(/&amp;/g, '&') ?? '',
    tracks: r['tracks']?.split(',').map((t: string) => t.trim()).filter((t: string) => t && t !== 'No tracks found for this session') ?? [],
    format: r['format']?.trim() ?? '',
    passes: r['passes']?.split(',').map((p: string) => p.trim()).filter(Boolean) ?? [],
    speakers: r['speakers']?.trim() ?? '',
    recorded: r['gdc vault recording']?.trim() ?? '',
  }))
  .filter((s) => DAY_ORDER.includes(s.day) && s.startMinutes >= 0);

const sessionsByDay: Record<string, Session[]> = {};
for (const day of DAY_ORDER) sessionsByDay[day] = sessions.filter((s) => s.day === day);

const locationsByDay: Record<string, string[]> = {};
for (const day of DAY_ORDER) {
  const locs = [...new Set(sessionsByDay[day].map((s) => s.location).filter(Boolean))];
  locs.sort((a, b) => {
    const am = a.match(/^(\d+),\s*(.+)$/), bm = b.match(/^(\d+),\s*(.+)$/);
    if (am && bm) { const bc = am[2].localeCompare(bm[2]); return bc !== 0 ? bc : parseInt(am[1]) - parseInt(bm[1]); }
    if (am) return -1; if (bm) return 1;
    return a.localeCompare(b);
  });
  locationsByDay[day] = locs;
}

const allTracks = [...new Set(sessions.flatMap((s) => s.tracks))].sort();
const allFormats = [...new Set(sessions.map((s) => s.format).filter(Boolean))].sort();
const allPasses = [...new Set(sessions.flatMap((s) => s.passes))].sort();

const TRACK_COLORS: Record<string, string> = {
  'Audio': '#8b5cf6',
  'Business Strategy': '#0ea5e9',
  'Career': '#14b8a6',
  'Culture & Sustainability': '#22c55e',
  'Design': '#f59e0b',
  'Discovery & Marketing': '#f97316',
  'Educators': '#ec4899',
  'Game & Production Technology': '#6366f1',
  'Independent Development': '#84cc16',
  'Luminaries Speaker Series': '#fbbf24',
  'Narrative & Performance': '#a78bfa',
  'Product Management': '#38bdf8',
  'Production': '#34d399',
  'Special Event': '#fb7185',
  'Team Leadership': '#fb923c',
  'Visual Development': '#c084fc',
};

const DAY_START = 9 * 60;
const DAY_END = 23 * 60;

const pageData = JSON.stringify({ sessionsByDay, locationsByDay, DAY_ORDER, DAY_START, DAY_END, TRACK_COLORS, allTracks, allFormats, allPasses });
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GDC 2026 Schedule</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0d0f18;
      --surface: #151722;
      --surface2: #1c1f30;
      --border: #252840;
      --border2: #2e3350;
      --text: #dde3f0;
      --muted: #8e98b0;
      --muted2: #a8b4cc;
      --accent: #6366f1;
      --accent-dim: #6366f133;
    }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── Header shell ── */
    #appHeader {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 100;
    }

    .header-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px 0;
      gap: 10px;
    }
    .header-top h1 {
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--text);
      white-space: nowrap;
    }
    .header-top h1 span {
      color: var(--muted2);
      font-weight: 400;
    }

    /* filter toggle button */
    #filterToggle {
      display: flex; align-items: center; gap: 6px;
      padding: 5px 11px;
      background: var(--surface2);
      border: 1px solid var(--border2);
      border-radius: 8px;
      color: var(--muted2);
      font-size: 0.78rem; font-weight: 500;
      cursor: pointer;
      white-space: nowrap;
      transition: color 0.15s, border-color 0.15s;
      flex-shrink: 0;
    }
    #filterToggle:hover { color: var(--text); border-color: var(--accent); }
    #filterToggle svg { opacity: 0.7; transition: transform 0.2s; }
    #filterToggle.open svg { transform: rotate(180deg); }
    #filterToggle .filter-count {
      background: var(--accent);
      color: #fff;
      border-radius: 999px;
      padding: 0 6px;
      font-size: 0.68rem;
      font-weight: 600;
      line-height: 1.6;
      display: none;
    }
    #filterToggle .filter-count.visible { display: inline; }

    /* ── Day tabs ── */
    #dayTabs {
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
      padding: 10px 14px 10px;
      gap: 6px;
    }
    #dayTabs::-webkit-scrollbar { display: none; }

    .day-tab {
      display: flex; flex-direction: column; align-items: center;
      padding: 7px 16px;
      border-radius: 10px;
      border: 1px solid var(--border2);
      background: var(--surface2);
      color: var(--muted2);
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      position: relative;
    }
    .day-tab:hover { background: var(--border2); color: var(--text); }
    .day-tab .tab-day { font-size: 0.85rem; font-weight: 600; line-height: 1; }
    .day-tab .tab-date { font-size: 0.68rem; margin-top: 3px; opacity: 0.75; }
    .day-tab.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    .day-tab.active .tab-date { opacity: 0.8; }
    .day-tab.today .tab-day::after {
      content: '·';
      color: #4ade80;
      margin-left: 4px;
    }

    /* ── Filter panel ── */
    #filterPanel {
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.25s ease;
      background: var(--surface2);
      border-top: 1px solid var(--border);
    }
    #filterPanel.open { max-height: 600px; }

    .filter-panel-inner {
      padding: 12px 16px 14px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .filter-group { display: flex; flex-direction: column; gap: 6px; }
    .filter-group-header {
      display: flex; align-items: center; justify-content: space-between;
    }
    .filter-group-title {
      font-size: 0.62rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }
    .filter-group-actions {
      display: flex; gap: 4px;
    }
    .filter-group-btn {
      font-size: 0.65rem; font-weight: 500;
      padding: 1px 7px;
      border-radius: 4px;
      border: 1px solid var(--border2);
      background: transparent;
      color: var(--muted2);
      cursor: pointer;
      transition: color 0.12s, border-color 0.12s;
    }
    .filter-group-btn:hover { color: var(--text); border-color: var(--muted2); }

    .filter-badges { display: flex; flex-wrap: wrap; gap: 5px; }

    .badge {
      padding: 3px 10px;
      border-radius: 6px;
      border: 1px solid transparent;
      font-size: 0.7rem; font-weight: 500;
      cursor: pointer; white-space: nowrap;
      user-select: none;
      transition: opacity 0.15s, filter 0.15s;
      display: inline-flex; align-items: center; gap: 5px;
    }
    .badge .badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .badge.off {
      opacity: 0.3;
      filter: grayscale(0.7);
    }

    /* ── Desktop grid ── */
    #gridWrapper { flex: 1; overflow: auto; min-height: 0; }
    #gridContainer { display: inline-block; min-width: 100%; }

    /* Session cards */
    .scard-time { font-size: 0.58rem; opacity: 0.65; }

    /* Session cards */
    .scard {
      position: absolute; left: 2px; right: 2px;
      border-radius: 5px; padding: 4px 7px;
      font-size: 0.68rem; line-height: 1.35; cursor: pointer;
      overflow: hidden; border-left: 3px solid;
      transition: opacity 0.15s, filter 0.15s;
    }
    .scard:hover { filter: brightness(1.25); }
    .scard.off { opacity: 0.06; pointer-events: none; }
    .scard-title { font-weight: 600; margin-bottom: 2px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .scard-time { font-size: 0.58rem; opacity: 0.65; }

    /* Now line */
    .now-line { position: absolute; left: 0; right: 0; border-top: 2px solid #ef4444; z-index: 15; pointer-events: none; }
    .now-dot { position: absolute; left: -4px; top: -4px; width: 8px; height: 8px; background: #ef4444; border-radius: 50%; }

    /* ── Mobile list ── */
    #mobileList { padding: 0 14px 24px; background: var(--bg); }
    .mtime-label {
      font-size: 0.75rem; font-weight: 700; color: var(--accent);
      border-bottom: 1px solid var(--border);
      padding: 10px 0 5px; margin-bottom: 8px;
      position: sticky; top: 0; background: var(--bg); z-index: 10;
    }
    .mcard {
      background: var(--surface); border: 1px solid var(--border);
      border-left: 3px solid; border-radius: 8px;
      padding: 9px 12px; margin-bottom: 7px; cursor: pointer;
      transition: border-color 0.12s;
    }
    .mcard:hover { border-color: var(--border2); }
    .mcard.off { display: none; }
    .mcard-title { font-size: 0.84rem; font-weight: 600; margin-bottom: 4px; line-height: 1.4; }
    .mcard-meta { font-size: 0.7rem; color: var(--muted2); }

    /* ── Modal ── */
    #modalOverlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.7);
      z-index: 200; align-items: center; justify-content: center; padding: 14px;
    }
    #modalOverlay.open { display: flex; }
    #modal {
      background: var(--surface); border: 1px solid var(--border2);
      border-radius: 14px; max-width: 580px; width: 100%;
      max-height: 88dvh; overflow-y: auto; padding: 22px;
    }
    .modal-close {
      float: right; margin-left: 12px; margin-bottom: 8px;
      background: var(--surface2); border: 1px solid var(--border2); color: var(--muted2);
      border-radius: 8px; padding: 4px 12px; cursor: pointer;
      font-size: 0.78rem; font-weight: 500;
      transition: color 0.12s;
    }
    .modal-close:hover { color: var(--text); }
    .modal-title { font-size: 1.05rem; font-weight: 700; line-height: 1.4; margin-bottom: 12px; }
    .modal-badges { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 16px; }
    .modal-badge {
      padding: 3px 10px; border-radius: 6px; border: 1px solid transparent;
      font-size: 0.7rem; font-weight: 500;
    }
    .modal-section { margin-bottom: 14px; }
    .modal-section h3 {
      font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--muted); margin-bottom: 5px; font-weight: 700;
    }
    .modal-section p { font-size: 0.84rem; line-height: 1.65; white-space: pre-wrap; color: var(--text); }

    /* view toggle (desktop only) */
    #viewToggle {
      display: flex;
      border: 1px solid var(--border2);
      border-radius: 8px;
      overflow: hidden;
      flex-shrink: 0;
    }
    .view-btn {
      display: flex; align-items: center; justify-content: center;
      padding: 5px 9px;
      background: var(--surface2);
      border: none;
      color: var(--muted2);
      cursor: pointer;
      transition: background 0.12s, color 0.12s;
    }
    .view-btn + .view-btn { border-left: 1px solid var(--border2); }
    .view-btn:hover { background: var(--border2); color: var(--text); }
    .view-btn.active { background: var(--accent); color: #fff; }

    /* JS controls visibility via .list-mode on body — works at all screen sizes */
    body:not(.list-mode) #mobileList { display: none; }
    body.list-mode #gridWrapper { display: none; }
    body.list-mode #mobileList { flex: 1; overflow-y: auto; min-height: 0; }

    @media (max-width: 640px) {
      .header-top { padding: 8px 10px 0; gap: 6px; }
      .header-top h1 { font-size: 0.85rem; }
      .btn-label { display: none; }
      #filterToggle { padding: 5px 8px; gap: 4px; }
    }

    /* ── Toolbar extra buttons ── */
    .tool-btn {
      display: flex; align-items: center; gap: 5px;
      padding: 5px 11px;
      background: var(--surface2);
      border: 1px solid var(--border2);
      border-radius: 8px;
      color: var(--muted2);
      font-size: 0.78rem; font-weight: 500;
      cursor: pointer; white-space: nowrap;
      transition: color 0.15s, border-color 0.15s, background 0.15s;
      flex-shrink: 0;
    }
    .tool-btn:hover { color: var(--text); border-color: var(--accent); }
    .tool-btn.active { background: var(--accent-dim); border-color: var(--accent); color: var(--accent); }
    #jumpToNow { display: none; }

    /* ── Interest states ── */
    .scard.interest-yes { box-shadow: 0 0 0 1.5px #fbbf24; }
    .scard.interest-no:not(.off) { opacity: 0.12; }
    .mcard.interest-yes { outline: 1.5px solid #fbbf24; outline-offset: -1px; }
    .mcard.interest-no { opacity: 0.15; }
    .interest-star { position: absolute; top: 3px; right: 4px; font-size: 0.65rem; line-height: 1; pointer-events: none; }
    .mcard .interest-star { position: static; display: inline; margin-left: 6px; font-size: 0.75rem; vertical-align: middle; }

    /* ── Interest buttons in modal ── */
    .interest-actions { display: flex; gap: 8px; margin-bottom: 16px; }
    .interest-btn {
      flex: 1; padding: 7px 12px; border-radius: 8px;
      border: 1px solid var(--border2); background: var(--surface2);
      color: var(--muted2); font-size: 0.78rem; font-weight: 500;
      cursor: pointer; transition: all 0.15s;
    }
    .interest-btn:hover { color: var(--text); border-color: var(--muted2); }
    .interest-btn.active-yes { background: #fbbf2420; border-color: #fbbf24; color: #fbbf24; }
    .interest-btn.active-no { background: #ef444420; border-color: #ef4444; color: #ef4444; }
  </style>
</head>
<body>

<header id="appHeader">
  <div class="header-top">
    <h1>GDC 2026</h1>
    <div style="display:flex;gap:8px;align-items:center;">
    <div id="viewToggle">
      <button class="view-btn active" data-view="grid" title="Calendar view">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
          <rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/>
          <rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/>
        </svg>
      </button>
      <button class="view-btn" data-view="list" title="List view">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
          <line x1="5" y1="4" x2="14" y2="4"/><line x1="5" y1="8" x2="14" y2="8"/><line x1="5" y1="12" x2="14" y2="12"/>
          <circle cx="2" cy="4" r="1" fill="currentColor" stroke="none"/>
          <circle cx="2" cy="8" r="1" fill="currentColor" stroke="none"/>
          <circle cx="2" cy="12" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </button>
    </div>
    <button id="jumpToNow" class="tool-btn" title="Jump to current time">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="8" cy="8" r="6"/><polyline points="8,5 8,8 10,10"/>
      </svg>
      <span class="btn-label">Now</span>
    </button>
    <button id="interestedOnlyBtn" class="tool-btn" title="Show interested only">
      ⭐<span class="btn-label"> Only</span>
    </button>
    <button id="hideSponsoredBtn" class="tool-btn" title="Hide sponsored / presented-by talks">
      No Ads
    </button>
    <button id="filterToggle">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="2" y1="4" x2="14" y2="4"/><line x1="4" y1="8" x2="12" y2="8"/><line x1="6" y1="12" x2="10" y2="12"/>
      </svg>
      <span class="btn-label">Filters</span>
      <span class="filter-count" id="filterCount"></span>
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="2,3 5,7 8,3"/>
      </svg>
    </button>
    </div>
  </div>

  <div id="dayTabs"></div>

  <div id="filterPanel">
    <div class="filter-panel-inner" id="filterArea"></div>
  </div>
</header>

<div id="gridWrapper"><div id="gridContainer"></div></div>
<div id="mobileList"></div>

<div id="modalOverlay">
  <div id="modal">
    <button class="modal-close" id="modalClose">✕ Close</button>
    <div id="modalContent"></div>
  </div>
</div>

<script define:vars={{ pageData }}>
const { sessionsByDay, locationsByDay, DAY_ORDER, DAY_START, DAY_END, TRACK_COLORS, allTracks, allFormats, allPasses } = JSON.parse(pageData);
const PX = 4; // pixels per minute
const MINS = DAY_END - DAY_START;

const DAY_NUMS  = { Monday:'2026-03-09', Tuesday:'2026-03-10', Wednesday:'2026-03-11', Thursday:'2026-03-12', Friday:'2026-03-13' };
const todayISO = new Date().toLocaleDateString('en-CA', { timeZone: 'America/Los_Angeles' });
let activeDay = DAY_ORDER.find(d => DAY_NUMS[d] === todayISO) || DAY_ORDER[0];

// ── Filter state (localStorage) ──
const FILTER_KEY = 'gdc2026-filters';
function loadFilters() {
  try {
    const saved = JSON.parse(localStorage.getItem(FILTER_KEY) || 'null');
    if (!saved) return { tracks: new Set(allTracks), formats: new Set(allFormats), passes: new Set(allPasses), interestedOnly: false, hideSponsored: false };
    // Intersect saved values with currently available ones (in case data changes)
    return {
      tracks: new Set(allTracks.filter(v => saved.tracks?.includes(v))),
      formats: new Set(allFormats.filter(v => saved.formats?.includes(v))),
      passes: new Set(allPasses.filter(v => saved.passes?.includes(v))),
      interestedOnly: saved.interestedOnly ?? false,
      hideSponsored: saved.hideSponsored ?? false,
    };
  } catch { return { tracks: new Set(allTracks), formats: new Set(allFormats), passes: new Set(allPasses), interestedOnly: false, hideSponsored: false }; }
}
function saveFilters() {
  localStorage.setItem(FILTER_KEY, JSON.stringify({
    tracks: [...on.tracks], formats: [...on.formats], passes: [...on.passes], interestedOnly, hideSponsored,
  }));
}

const { tracks: _t, formats: _f, passes: _p, interestedOnly: _io, hideSponsored: _hs } = loadFilters();
const on = { tracks: _t, formats: _f, passes: _p };
let interestedOnly = _io;
let hideSponsored = _hs;

function isSponsored(s) { return /\(Presented by /i.test(s.title); }

// ── Interest state (localStorage) ──
const INTEREST_KEY = 'gdc2026-interests';
function loadInterests() {
  try { return JSON.parse(localStorage.getItem(INTEREST_KEY) || '{}'); } catch { return {}; }
}
function saveInterests() { localStorage.setItem(INTEREST_KEY, JSON.stringify(interests)); }
let interests = loadInterests();

function getInterest(s) { return interests[s.title] || 'neutral'; }
function setInterest(s, state) {
  if (state === 'neutral') delete interests[s.title];
  else interests[s.title] = state;
  saveInterests();
  applyAllInterestStyles();
  if (currentModalSession?.title === s.title) renderModalInterestButtons(getInterest(s));
}
function applyInterestToEl(el) {
  if (!el._s) return;
  const st = getInterest(el._s);
  el.classList.toggle('interest-yes', st === 'interested');
  el.classList.toggle('interest-no', st === 'not-interested');
  const star = el.querySelector('.interest-star');
  if (star) star.style.display = st === 'interested' ? '' : 'none';
}
function applyAllInterestStyles() {
  document.querySelectorAll('.scard, .mcard').forEach(applyInterestToEl);
}

// ── Interested-only toggle ──
document.getElementById('interestedOnlyBtn').addEventListener('click', () => {
  interestedOnly = !interestedOnly;
  document.getElementById('interestedOnlyBtn').classList.toggle('active', interestedOnly);
  applyVisibility();
  saveFilters();
});

// ── Hide sponsored toggle ──
document.getElementById('hideSponsoredBtn').addEventListener('click', () => {
  hideSponsored = !hideSponsored;
  document.getElementById('hideSponsoredBtn').classList.toggle('active', hideSponsored);
  applyVisibility();
  saveFilters();
});

// ── Jump to Now ──
function updateJumpToNowVisibility() {
  const { ptDay } = getPTNow();
  document.getElementById('jumpToNow').style.display = ptDay === activeDay ? 'flex' : 'none';
}

function jumpToNow() {
  const { ptNow, ptDay } = getPTNow();
  if (ptDay !== activeDay) return;
  const nowMin = ptNow.getHours()*60 + ptNow.getMinutes();
  if (document.body.classList.contains('list-mode')) {
    const bar = document.getElementById('list-now-marker');
    if (bar) bar.scrollIntoView({ behavior: 'smooth', block: 'center' });
  } else {
    if (nowMin < DAY_START || nowMin > DAY_END) return;
    const wrapper = document.getElementById('gridWrapper');
    const top = (nowMin - DAY_START) * PX;
    wrapper.scrollTo({ top: top - wrapper.clientHeight / 3, behavior: 'smooth' });
  }
}
document.getElementById('jumpToNow').addEventListener('click', jumpToNow);

// ── Helpers ──
function fmt(isoStr) {
  const t = isoStr.includes(' ') ? isoStr.split(' ')[1] : isoStr;
  const [h, m] = t.split(':').map(Number);
  return `${h % 12 || 12}:${String(m).padStart(2,'0')} ${h >= 12 ? 'PM' : 'AM'}`;
}
function color(s) { return TRACK_COLORS[s.tracks[0]] ?? '#64748b'; }
function visible(s) {
  if (hideSponsored && isSponsored(s)) return false;
  const tOk = s.tracks.length === 0 || s.tracks.some(t => on.tracks.has(t));
  const fOk = !s.format || on.formats.has(s.format);
  const pOk = s.passes.length === 0 || s.passes.some(p => on.passes.has(p));
  return tOk && fOk && pOk;
}
function locLabel(loc) {
  const m = loc.match(/^(\d+),\s*(.+)$/);
  return m ? `<span style="font-size:0.82rem;font-weight:600;color:var(--text)">${m[1]}</span><br><span style="font-size:0.62rem;color:var(--muted2)">${m[2]}</span>`
           : `<span style="font-size:0.65rem">${loc}</span>`;
}

// GDC 2026 dates
const DAY_DATES = { Monday:'Mar 9', Tuesday:'Mar 10', Wednesday:'Mar 11', Thursday:'Mar 12', Friday:'Mar 13' };

// ── Day tabs ──
function buildDayTabs() {
  const el = document.getElementById('dayTabs');
  el.innerHTML = '';
  for (const day of DAY_ORDER) {
    const isToday = DAY_NUMS[day] === todayISO;
    const btn = document.createElement('button');
    btn.className = 'day-tab' + (day === activeDay ? ' active' : '') + (isToday ? ' today' : '');
    btn.dataset.day = day;
    btn.innerHTML = `<span class="tab-day">${day}</span><span class="tab-date">${DAY_DATES[day]}</span>`;
    el.appendChild(btn);
  }
}
document.getElementById('dayTabs').addEventListener('click', e => {
  const btn = e.target.closest('.day-tab');
  if (!btn) return;
  activeDay = btn.dataset.day;
  document.querySelectorAll('.day-tab').forEach(b => b.classList.toggle('active', b.dataset.day === activeDay));
  buildView();
  updateJumpToNowVisibility();
});

// ── Filter panel toggle ──
document.getElementById('filterToggle').addEventListener('click', () => {
  document.getElementById('filterToggle').classList.toggle('open');
  document.getElementById('filterPanel').classList.toggle('open');
});

function updateFilterCount() {
  const hidden = [...document.querySelectorAll('.badge')].filter(b => b.classList.contains('off')).length;
  const cnt = document.getElementById('filterCount');
  cnt.textContent = hidden;
  cnt.classList.toggle('visible', hidden > 0);
  saveFilters();
}

// ── Filter badges ──
function makeGroup(el, label, items, ft, badgeFn) {
  const grp = document.createElement('div'); grp.className = 'filter-group';
  const hdr = document.createElement('div'); hdr.className = 'filter-group-header';
  const title = document.createElement('span'); title.className = 'filter-group-title'; title.textContent = label;
  const actions = document.createElement('div'); actions.className = 'filter-group-actions';
  const allBtn = document.createElement('button'); allBtn.className = 'filter-group-btn'; allBtn.textContent = 'All';
  allBtn.addEventListener('click', () => { items.forEach(v => on[ft].add(v)); syncBadges(); applyVisibility(); updateFilterCount(); });
  const noneBtn = document.createElement('button'); noneBtn.className = 'filter-group-btn'; noneBtn.textContent = 'None';
  noneBtn.addEventListener('click', () => { items.forEach(v => on[ft].delete(v)); syncBadges(); applyVisibility(); updateFilterCount(); });
  actions.appendChild(allBtn); actions.appendChild(noneBtn);
  hdr.appendChild(title); hdr.appendChild(actions); grp.appendChild(hdr);
  const badges = document.createElement('div'); badges.className = 'filter-badges';
  for (const v of items) badges.appendChild(badgeFn(v, ft));
  grp.appendChild(badges); el.appendChild(grp);
}

function buildFilters() {
  const el = document.getElementById('filterArea');
  el.innerHTML = '';
  makeGroup(el, 'Track', allTracks, 'tracks', (t) => {
    const c = TRACK_COLORS[t] ?? '#666';
    const b = document.createElement('button');
    b.className = 'badge'; b.dataset.ft = 'tracks'; b.dataset.fv = t;
    b.style.cssText = `background:${c}18;border-color:${c}50;color:${c}`;
    const dot = document.createElement('span'); dot.className = 'badge-dot'; dot.style.background = c;
    b.appendChild(dot); b.appendChild(document.createTextNode(t));
    return b;
  });
  makeGroup(el, 'Format', allFormats, 'formats', (f) => {
    const b = document.createElement('button');
    b.className = 'badge'; b.dataset.ft = 'formats'; b.dataset.fv = f;
    b.style.cssText = `background:#ffffff0d;border-color:#ffffff22;color:var(--text)`;
    b.textContent = f || 'Unknown';
    return b;
  });
  makeGroup(el, 'Pass', allPasses, 'passes', (p) => {
    const b = document.createElement('button');
    b.className = 'badge'; b.dataset.ft = 'passes'; b.dataset.fv = p;
    b.style.cssText = `background:#ffffff0d;border-color:#ffffff22;color:var(--muted2)`;
    b.textContent = p;
    return b;
  });
  syncBadges();
}

function syncBadges() {
  document.querySelectorAll('.badge').forEach(b => {
    b.classList.toggle('off', !on[b.dataset.ft]?.has(b.dataset.fv));
  });
}

document.getElementById('filterArea').addEventListener('click', e => {
  const b = e.target.closest('.badge');
  if (!b) return;
  const set = on[b.dataset.ft];
  if (set.has(b.dataset.fv)) set.delete(b.dataset.fv); else set.add(b.dataset.fv);
  syncBadges(); applyVisibility(); updateFilterCount();
});

function applyVisibility() {
  document.querySelectorAll('.scard').forEach(el => {
    const hide = !visible(el._s) || (interestedOnly && getInterest(el._s) !== 'interested');
    el.classList.toggle('off', hide);
  });
  document.querySelectorAll('.mcard').forEach(el => {
    const hide = !visible(el._s) || (interestedOnly && getInterest(el._s) !== 'interested');
    el.classList.toggle('off', hide);
  });
  updateColVisibility();
}

function updateColVisibility() {
  for (const { col, hdr } of gridCols) {
    const hasVisible = col.querySelector('.scard:not(.off)') !== null;
    col.style.display = hasVisible ? '' : 'none';
    hdr.style.display = hasVisible ? '' : 'none';
  }
}

// ── Desktop grid ──
const COL_W = 165; // px per location column
let gridCols = []; // { col, hdr } pairs, rebuilt on each buildGrid
let gridNowLineCols = []; // column elements for now-line updates

function buildGrid() {
  const sessions = sessionsByDay[activeDay] ?? [];
  const locs = locationsByDay[activeDay] ?? [];
  const h = MINS * PX;
  const gc = document.getElementById('gridContainer');
  gc.innerHTML = '';
  gridCols = [];
  gridNowLineCols = [];

  // ── Sticky header row (flex) ──
  const hdrRow = document.createElement('div');
  hdrRow.style.cssText = `position:sticky;top:0;z-index:30;display:flex;background:var(--surface);border-bottom:2px solid var(--border2);`;

  const corner = document.createElement('div');
  corner.style.cssText = `position:sticky;left:0;z-index:40;width:58px;min-width:58px;background:var(--bg);border-right:1px solid var(--border);border-bottom:2px solid var(--border2);margin-bottom:-2px;`;
  hdrRow.appendChild(corner);

  const locHdrs = locs.map(loc => {
    const hdr = document.createElement('div');
    hdr.style.cssText = `width:${COL_W}px;min-width:${COL_W}px;padding:5px 8px;font-size:0.68rem;text-align:center;line-height:1.4;border-right:1px solid var(--border);`;
    hdr.innerHTML = locLabel(loc);
    hdrRow.appendChild(hdr);
    return hdr;
  });
  gc.appendChild(hdrRow);

  // ── Body row (flex) ──
  const bodyRow = document.createElement('div');
  bodyRow.style.cssText = `display:flex;`;

  // Sticky time column
  const tc = document.createElement('div');
  tc.style.cssText = `position:sticky;left:0;z-index:20;background:var(--bg);border-right:1px solid var(--border);width:58px;min-width:58px;height:${h}px;`;
  for (let m = 0; m < MINS; m += 30) {
    const tick = document.createElement('div');
    tick.style.cssText = `height:${30*PX}px;display:flex;align-items:flex-start;justify-content:flex-end;padding:2px 8px 0 0;font-size:0.65rem;font-weight:500;color:var(--muted2);border-top:1px solid var(--border);`;
    const abs = DAY_START + m, hr = Math.floor(abs/60), mn = abs%60;
    if (mn === 0) tick.textContent = `${hr%12||12}${hr>=12?'p':'a'}`;
    tc.appendChild(tick);
  }
  bodyRow.appendChild(tc);

  // Location columns — each is a plain div with position:relative
  const locIdx = Object.fromEntries(locs.map((l,i) => [l,i]));
  const cols = locs.map((_, i) => {
    const col = document.createElement('div');
    col.style.cssText = `position:relative;width:${COL_W}px;min-width:${COL_W}px;height:${h}px;border-right:1px solid var(--border);`;
    for (let m = 0; m <= MINS; m += 30) {
      const line = document.createElement('div');
      line.style.cssText = `position:absolute;left:0;right:0;top:${m*PX}px;border-top:1px solid ${m%60===0?'var(--border)':'rgba(255,255,255,0.04)'};pointer-events:none;`;
      col.appendChild(line);
    }
    bodyRow.appendChild(col);
    gridCols.push({ col, hdr: locHdrs[i] });
    return col;
  });
  gc.appendChild(bodyRow);

  // Place sessions
  for (const s of sessions) {
    const idx = locIdx[s.location];
    if (idx === undefined) continue;
    const top = Math.max(0, (s.startMinutes - DAY_START) * PX);
    const ht = Math.max((s.endMinutes - s.startMinutes) * PX - 2, 22);
    const c = color(s);

    const card = document.createElement('div');
    card.className = 'scard' + (visible(s) ? '' : ' off');
    card.style.cssText = `top:${top}px;height:${ht}px;border-left-color:${c};background:${c}20;`;
    card._s = s;

    const titleEl = document.createElement('div');
    titleEl.style.cssText = `font-weight:600;margin-bottom:2px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;`;
    titleEl.textContent = s.title;
    card.appendChild(titleEl);

    if (ht > 44) {
      const time = document.createElement('div');
      time.className = 'scard-time';
      time.textContent = `${fmt(s.startTime)}–${fmt(s.endTime)}`;
      card.appendChild(time);
    }

    const star = document.createElement('span');
    star.className = 'interest-star';
    star.textContent = '⭐';
    star.style.display = 'none';
    card.appendChild(star);

    card.addEventListener('click', () => openModal(s));
    applyInterestToEl(card);
    cols[idx].appendChild(card);
  }

  gridNowLineCols = cols;
  updateNowLine();
}

// ── Now line (real-time) ──
function getPTNow() {
  const ptNow = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Los_Angeles' }));
  const ptDay = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][ptNow.getDay()];
  return { ptNow, ptDay };
}

function updateNowLine() {
  const { ptNow, ptDay } = getPTNow();
  const nowMin = ptNow.getHours()*60 + ptNow.getMinutes();

  // Grid: remove stale indicators and re-place at current time
  document.querySelectorAll('.now-line-indicator').forEach(el => el.remove());
  if (ptDay === activeDay && nowMin >= DAY_START && nowMin <= DAY_END) {
    const top = (nowMin - DAY_START) * PX;
    gridNowLineCols.forEach(col => {
      const line = document.createElement('div');
      line.className = 'now-line-indicator';
      line.style.cssText = `position:absolute;left:0;right:0;top:${top}px;border-top:2px solid #ef4444;z-index:15;pointer-events:none;`;
      const dot = document.createElement('div');
      dot.style.cssText = `position:absolute;left:-4px;top:-4px;width:8px;height:8px;background:#ef4444;border-radius:50%;`;
      line.appendChild(dot);
      col.appendChild(line);
    });
  }

  // List: update now-bar time text
  const nowBar = document.getElementById('list-now-marker');
  if (nowBar) {
    const span = nowBar.querySelector('.now-time');
    if (span && ptDay === activeDay) {
      span.textContent = `Now · ${ptNow.getHours()%12||12}:${String(ptNow.getMinutes()).padStart(2,'0')} ${ptNow.getHours()>=12?'PM':'AM'} PT`;
    }
  }
}

setInterval(updateNowLine, 60000);

// ── Mobile list ──
function buildMobileList() {
  const sessions = sessionsByDay[activeDay] ?? [];
  const ml = document.getElementById('mobileList');
  ml.innerHTML = '';

  const groups = {};
  for (const s of sessions) { if (!groups[s.startTime]) groups[s.startTime] = []; groups[s.startTime].push(s); }

  const { ptNow, ptDay } = getPTNow();
  const nowMin = ptDay === activeDay ? ptNow.getHours()*60 + ptNow.getMinutes() : -1;
  let nowInserted = false;

  for (const key of Object.keys(groups).sort()) {
    const keyMin = key.includes(' ') ? (() => { const [h,m] = key.split(' ')[1].split(':').map(Number); return h*60+m; })() : -1;

    if (!nowInserted && nowMin >= 0 && keyMin > nowMin) {
      const timeStr = `${ptNow.getHours()%12||12}:${String(ptNow.getMinutes()).padStart(2,'0')} ${ptNow.getHours()>=12?'PM':'AM'} PT`;
      const nowBar = document.createElement('div');
      nowBar.id = 'list-now-marker';
      nowBar.style.cssText = `display:flex;align-items:center;gap:8px;margin:4px 0 16px;`;
      nowBar.innerHTML = `<div style="flex:1;height:2px;background:#ef4444;border-radius:1px;"></div><span class="now-time" style="font-size:0.7rem;font-weight:700;color:#ef4444;white-space:nowrap;">Now · ${timeStr}</span><div style="flex:1;height:2px;background:#ef4444;border-radius:1px;"></div>`;
      ml.appendChild(nowBar);
      nowInserted = true;
    }

    const grp = document.createElement('div'); grp.style.marginBottom = '18px';
    const lbl = document.createElement('div'); lbl.className = 'mtime-label'; lbl.textContent = fmt(key);
    grp.appendChild(lbl);

    for (const s of groups[key]) {
      const c = color(s);
      const card = document.createElement('div');
      card.className = 'mcard' + (visible(s) ? '' : ' off');
      card.style.borderLeftColor = c; card._s = s;

      const titleEl = document.createElement('div');
      titleEl.className = 'mcard-title';
      titleEl.textContent = s.title;
      const star = document.createElement('span');
      star.className = 'interest-star';
      star.textContent = '⭐';
      star.style.display = 'none';
      titleEl.appendChild(star);
      card.appendChild(titleEl);

      const meta = document.createElement('div');
      meta.className = 'mcard-meta';
      meta.textContent = `${s.location}${s.format ? ' · '+s.format : ''} · ${fmt(s.startTime)}–${fmt(s.endTime)}`;
      card.appendChild(meta);

      card.addEventListener('click', () => openModal(s));
      applyInterestToEl(card);
      grp.appendChild(card);
    }
    ml.appendChild(grp);
  }
}

// ── Modal ──
let currentModalSession = null;

function renderModalInterestButtons(state) {
  const container = document.getElementById('modal-interest-actions');
  if (!container) return;
  container.innerHTML = '';
  for (const [st, label, activeClass] of [
    ['interested', '⭐ Interested', 'active-yes'],
    ['not-interested', '✕ Not Interested', 'active-no'],
  ]) {
    const btn = document.createElement('button');
    btn.className = 'interest-btn' + (state === st ? ' ' + activeClass : '');
    btn.textContent = label;
    btn.addEventListener('click', () => {
      const cur = getInterest(currentModalSession);
      setInterest(currentModalSession, cur === st ? 'neutral' : st);
    });
    container.appendChild(btn);
  }
}

function openModal(s) {
  currentModalSession = s;
  const c = color(s);
  document.getElementById('modalContent').innerHTML = `
    <div class="modal-title">${s.title}</div>
    <div id="modal-interest-actions" class="interest-actions"></div>
    <div class="modal-badges">
      ${s.tracks.length ? `<span class="badge" style="background:${c}30;border-color:${c}55;color:${c}">${s.tracks.join(', ')}</span>` : ''}
      ${s.format ? `<span class="badge" style="background:#fff1;border-color:#fff3;color:var(--text)">${s.format}</span>` : ''}
      ${s.passes.map(p=>`<span class="badge" style="background:#fff1;border-color:#fff2;color:var(--muted)">${p}</span>`).join('')}
    </div>
    <div class="modal-section"><h3>When & Where</h3><p>${s.day} · ${fmt(s.startTime)} – ${fmt(s.endTime)}<br>${s.location}</p></div>
    ${s.speakers && s.speakers !== 'No speakers found for this session' ? `<div class="modal-section"><h3>Speakers</h3><p>${s.speakers}</p></div>` : ''}
    ${s.description ? `<div class="modal-section"><h3>Description</h3><p>${s.description}</p></div>` : ''}
    ${s.recorded ? `<div class="modal-section"><h3>Recording</h3><p>${s.recorded}</p></div>` : ''}
  `;
  renderModalInterestButtons(getInterest(s));
  document.getElementById('modalOverlay').classList.add('open');
}
document.getElementById('modalClose').addEventListener('click', () => {
  document.getElementById('modalOverlay').classList.remove('open');
  currentModalSession = null;
});
document.getElementById('modalOverlay').addEventListener('click', e => {
  if (e.target === e.currentTarget) {
    document.getElementById('modalOverlay').classList.remove('open');
    currentModalSession = null;
  }
});

// ── View toggle ──
function setView(view) {
  document.querySelectorAll('.view-btn').forEach(b => b.classList.toggle('active', b.dataset.view === view));
  document.body.classList.toggle('list-mode', view === 'list');
}
// Default: list on mobile, grid on desktop
setView(window.innerWidth <= 640 ? 'list' : 'grid');

document.getElementById('viewToggle')?.addEventListener('click', e => {
  const btn = e.target.closest('.view-btn');
  if (!btn) return;
  setView(btn.dataset.view);
});

// ── Init ──
function buildView() { buildGrid(); buildMobileList(); applyVisibility(); }
buildDayTabs();
buildFilters();
updateFilterCount();
document.getElementById('interestedOnlyBtn').classList.toggle('active', interestedOnly);
document.getElementById('hideSponsoredBtn').classList.toggle('active', hideSponsored);
buildView();
updateJumpToNowVisibility();
</script>
</body>
</html>
