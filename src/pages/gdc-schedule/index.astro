---
import fs from 'fs';
import path from 'path';

// Find the latest year from available CSV files
const csvFiles = fs.readdirSync(path.resolve('./src/data')).filter(f => f.match(/^gdc-\d{4}\.csv$/));
const years = csvFiles.map(f => f.match(/^gdc-(\d{4})\.csv$/)![1]).sort();
const latestYear = years[years.length - 1];

return Astro.redirect(`/gdc-schedule/${latestYear}/`);
---
