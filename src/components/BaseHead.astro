---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "making stuff and things", image = "/images/logos/black-bg-icon.png" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
---

<script is:inline>
if (location.hostname === 'gmjosack.github.io') {
  location.replace('https://madebygare.com' + location.pathname + location.search + location.hash);
}
</script>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/png" href="/images/logos/black-bg-icon.png" />
<link rel="canonical" href={canonicalURL} />
<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content="Made By Gare" />

<!-- Twitter -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="Made By Gare" href="/rss.xml" />

<!-- Theme color -->
<meta name="theme-color" content="#f97316" />
