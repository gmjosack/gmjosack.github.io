---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const primary = project.primaryLink || (project.itchUrl ? 'itch' : project.steamUrl ? 'steam' : project.githubUrl ? 'github' : 'url');
const primaryClass = "text-xs font-medium px-3 py-1.5 rounded bg-accent-orange/10 text-accent-orange hover:bg-accent-orange/20 transition-colors";
const secondaryClass = "text-xs font-medium px-3 py-1.5 rounded bg-bg-tertiary text-text-secondary hover:text-text-primary transition-colors";

type LinkEntry = { href: string; label: string; key: string };
const links: LinkEntry[] = [
  project.itchUrl ? { href: project.itchUrl, label: 'itch.io', key: 'itch' } : null,
  project.steamUrl ? { href: project.steamUrl, label: 'Steam', key: 'steam' } : null,
  project.githubUrl ? { href: project.githubUrl, label: 'GitHub', key: 'github' } : null,
  project.url ? { href: project.url, label: 'Website', key: 'url' } : null,
].filter((l): l is LinkEntry => l !== null)
 .sort((a, b) => (a.key === primary ? -1 : b.key === primary ? 1 : 0));
---

{compact ? (
  <a
    href={project.githubUrl || project.url || '#'}
    target="_blank"
    rel="noopener noreferrer"
    class="bg-bg-secondary border border-bg-tertiary rounded-lg p-3 hover:border-accent-orange/30 transition-colors block"
  >
    <h4 class="text-sm font-semibold text-text-primary">{project.name}</h4>
    <p class="text-text-secondary text-xs mt-1">{project.description}</p>
  </a>
) : (
  <div class:list={[
    "bg-bg-secondary border border-bg-tertiary rounded-lg overflow-hidden hover:border-accent-orange/30 transition-colors",
    project.image ? "flex" : "",
  ]}>
    {project.image && (
      <img
        src={project.image}
        alt={project.name}
        class="w-48 shrink-0 object-cover"
      />
    )}
    <div class="p-5 flex flex-col justify-center">
      <h3 class="text-lg font-semibold text-text-primary mb-1">{project.name}</h3>
      <p class="text-text-secondary text-sm mb-3">{project.description}</p>
      <div class="flex gap-3 flex-wrap">
        {links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class={link.key === primary ? primaryClass : secondaryClass}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
)}
