---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  compact?: boolean;
  featured?: boolean;
}

const { project, compact = false, featured = false } = Astro.props;
const primary = project.primaryLink || (project.itchUrl ? 'itch' : project.steamUrl ? 'steam' : project.githubUrl ? 'github' : 'url');

function inlineMarkdown(text: string): string {
  return text
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer" class="text-accent-orange hover:underline">$1</a>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*]+)\*/g, '<em>$1</em>');
}

const contextHtml = project.context ? inlineMarkdown(project.context) : '';
const primaryClass = "text-xs font-medium px-3 py-1.5 rounded bg-accent-orange/10 text-accent-orange hover:bg-accent-orange/20 transition-colors";
const secondaryClass = "text-xs font-medium px-3 py-1.5 rounded bg-bg-tertiary text-text-secondary hover:text-text-primary transition-colors";

type LinkEntry = { href: string; label: string; key: string };
const links: LinkEntry[] = [
  project.itchUrl ? { href: project.itchUrl, label: 'itch.io', key: 'itch' } : null,
  project.steamUrl ? { href: project.steamUrl, label: 'Steam', key: 'steam' } : null,
  project.githubUrl ? { href: project.githubUrl, label: 'GitHub', key: 'github' } : null,
  project.url ? { href: project.url, label: 'Website', key: 'url' } : null,
].filter((l): l is LinkEntry => l !== null)
 .sort((a, b) => (a.key === primary ? -1 : b.key === primary ? 1 : 0));
---

{compact ? (
  <a
    href={project.githubUrl || project.url || '#'}
    target="_blank"
    rel="noopener noreferrer"
    class="bg-bg-secondary border border-bg-tertiary rounded-lg p-3 hover:border-accent-orange/30 transition-colors block"
  >
    <h4 class="text-sm font-semibold text-text-primary">{project.name}</h4>
    <p class="text-text-secondary text-xs mt-1">{project.description}</p>
  </a>
) : (
  <div class:list={[
    "bg-bg-secondary border border-bg-tertiary rounded-lg overflow-hidden hover:border-accent-orange/30 transition-colors h-full",
    project.image ? "flex flex-col sm:flex-row" : "flex flex-col",
  ]}>
    {project.image && (
      <div class:list={[
        "shrink-0 relative overflow-hidden flex items-center",
        featured ? "w-full sm:w-72" : "w-full sm:w-48",
      ]}>
        <div
          class="absolute inset-0 scale-125 blur-xl bg-cover bg-center opacity-50"
          style={`background-image: url('${project.image}');`}
        />
        <img
          src={project.image}
          alt={project.name}
          class="w-full object-cover relative z-10"
        />
      </div>
    )}
    <div class="flex flex-col flex-1">
      <div class:list={["flex flex-col justify-center flex-1", featured ? "p-6" : "p-5"]}>
        <h3 class:list={["font-semibold text-text-primary mb-1", featured ? "text-2xl" : "text-lg"]}>{project.name}</h3>
        <p class:list={["text-text-secondary", featured ? "text-base" : "text-sm"]}>{project.description}</p>
        {contextHtml && <p class="text-text-secondary/70 text-xs mt-2 italic"><Fragment set:html={contextHtml} /></p>}
      </div>
      {links.length > 0 && (
        <div class="flex border-t border-bg-tertiary">
          {links.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "flex-1 text-center text-xs font-medium py-2 transition-colors border-r border-bg-tertiary last:border-r-0",
                link.key === primary
                  ? "text-accent-orange hover:bg-accent-orange/10"
                  : "text-text-secondary hover:text-text-primary hover:bg-bg-tertiary",
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
)}
