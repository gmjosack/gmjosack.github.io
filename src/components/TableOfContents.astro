---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="toc h-full" aria-label="Table of Contents">
    <div class="sticky top-8">
      <p class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-3">On this page</p>
      <ul class="space-y-1.5 text-sm border-l border-bg-tertiary">
        {filtered.map(h => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                "toc-link block text-text-secondary hover:text-accent-orange transition-colors duration-150",
                h.depth === 2 ? "pl-3" : "pl-6",
              ]}
              data-slug={h.slug}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<script>
  function initToc() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (links.length === 0) return;

    const slugs = Array.from(links).map(l => l.dataset.slug!);
    let active: string | null = null;

    function setActive(slug: string) {
      if (slug === active) return;
      active = slug;
      links.forEach(l => {
        if (l.dataset.slug === slug) {
          l.classList.add('text-accent-orange', 'border-l-2', 'border-accent-orange', '-ml-px');
          l.classList.remove('text-text-secondary');
        } else {
          l.classList.remove('text-accent-orange', 'border-l-2', 'border-accent-orange', '-ml-px');
          l.classList.add('text-text-secondary');
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0 }
    );

    for (const slug of slugs) {
      const el = document.getElementById(slug);
      if (el) observer.observe(el);
    }

    // Set initial active
    if (slugs.length > 0) setActive(slugs[0]);
  }

  initToc();
  document.addEventListener('astro:after-swap', initToc);
</script>
