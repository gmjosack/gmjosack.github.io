---
interface Props {
  title: string;
  date: string;
  slug: string;
}

const { title, date, slug } = Astro.props;
---

<a href={`/posts/${slug}/`} class="block group">
  <article class="bg-bg-secondary border border-bg-tertiary rounded-lg p-5 hover:border-accent-orange/30 transition-colors">
    <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent-orange transition-colors mb-1">
      {title}
    </h3>
    <time class="text-text-secondary text-sm">{date}</time>
  </article>
</a>
