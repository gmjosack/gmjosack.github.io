---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Projects' },
  { href: '/resume/', label: 'Resume' },
  { href: '/posts/', label: 'Blog' },
];

const socialLinks = [
  { href: 'https://github.com/gmjosack', label: 'GitHub', icon: 'github' },
  { href: 'https://madebygare.itch.io/', label: 'itch.io', icon: 'itchio' },
  { href: 'https://store.steampowered.com/developer/madebygare', label: 'Steam', icon: 'steam' },
  { href: 'https://bsky.app/profile/madebygare.bsky.social', label: 'Bluesky', icon: 'bluesky' },
];
---

<header class="border-b border-bg-tertiary">
  <div class="mx-auto max-w-5xl px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/images/logos/black-bg-icon.png"
        alt="Made By Gare"
        class="h-10 rounded"
      />
      <span class="text-text-primary font-bold text-lg group-hover:text-accent-orange transition-colors">
        Made By Gare
      </span>
    </a>

    <nav class="flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors',
            pathname === href
              ? 'text-accent-orange'
              : 'text-text-secondary hover:text-text-primary',
          ]}
        >
          {label}
        </a>
      ))}

      <div class="w-px h-5 bg-bg-tertiary" />

      {socialLinks.map(({ href, label, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          title={label}
          class="text-text-secondary hover:text-accent-orange transition-colors"
        >
          {icon === 'github' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          )}
          {icon === 'itchio' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M3.13 1.338C2.076 1.922.947 3.15 0 4.523v.71c0 1.968 1.336 3.272 2.879 3.272 1.607 0 2.878-1.304 2.878-2.97 0 1.666 1.174 2.97 2.766 2.97 1.593 0 2.879-1.304 2.879-2.97 0 1.666 1.27 2.97 2.878 2.97 1.607 0 2.878-1.304 2.878-2.97 0 1.666 1.174 2.97 2.766 2.97 1.593 0 2.879-1.304 2.879-2.97 0 1.666 1.27 2.97 2.878 2.97 1.543 0 2.879-1.304 2.879-3.272v-.71c-.947-1.373-2.076-2.601-3.13-3.185C20.456.09 17.837 0 16.95 0H7.05c-.886 0-3.506.089-3.92.338zM24 10.2c-.463.886-1.324 1.523-2.521 1.523-1.2 0-2.234-.707-2.72-1.623-.48.916-1.456 1.623-2.656 1.623s-2.178-.707-2.656-1.623c-.479.916-1.457 1.623-2.656 1.623-1.2 0-2.178-.707-2.657-1.623-.478.916-1.456 1.623-2.655 1.623S3.26 11.016 2.78 10.1c-.486.916-1.52 1.623-2.72 1.623L0 11.707v8.572c0 1.746.37 2.444 1.707 3.383.8.563 4.397 1.037 6.14.338 1.273-.51 2.283-1.758 2.742-2.478.918-1.44.773-3.24.773-4.846v-2.44h1.221v2.44c0 1.605-.145 3.406.773 4.846.46.72 1.47 1.968 2.742 2.478 1.744.7 5.341.225 6.14-.338C23.63 22.723 24 22.025 24 20.279V11.707c-.018.006-.018.006-.06.016z"/></svg>
          )}
          {icon === 'steam' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.253 0-2.265-1.014-2.265-2.265z"/></svg>
          )}
          {icon === 'bluesky' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.6 3.476 6.154 3.228-4.486.428-8.395 1.572-4.638 5.579C5.487 22.56 8.87 21.598 12 16.936c3.13 4.662 6.404 5.57 9.86 2.118 3.757-4.007-.152-5.15-4.638-5.579 2.554.248 5.37-.601 6.154-3.228.246-.828.624-5.788.624-6.479 0-.688-.139-1.86-.902-2.203-.66-.3-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
          )}
        </a>
      ))}
    </nav>
  </div>
</header>
