---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<BaseLayout title={`${frontmatter.title} - Made By Gare`} description={frontmatter.description}>
  <article class="max-w-3xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2">{frontmatter.title}</h1>
      <time class="text-text-secondary text-sm">{frontmatter.date}</time>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
