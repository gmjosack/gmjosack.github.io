---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description?: string;
    coverImage?: string;
    coverImageAlt?: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;
---

<BaseLayout title={`${frontmatter.title} - Made By Gare`} description={frontmatter.description} image={frontmatter.coverImage}>
  <article class="max-w-3xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2">{frontmatter.title}</h1>
      <time class="text-text-secondary text-sm">{frontmatter.date}</time>
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {frontmatter.tags.map(tag => <TagBadge tag={tag} linked />)}
        </div>
      )}
    </header>
    {frontmatter.coverImage && (
      <div class="mb-8 rounded-lg overflow-hidden">
        <img
          src={frontmatter.coverImage}
          alt={frontmatter.coverImageAlt || frontmatter.title}
          class="w-full max-h-80 object-cover"
        />
      </div>
    )}
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
